-- Currently executing parallel SQL
PROMPT -- SQL currently using parallelism:
SELECT
    s.inst_id,
    s.sql_id,
    s.sql_text,
    q.px_servers_executions,
    q.executions,
    ROUND(q.elapsed_time/1000000,2)     AS elapsed_secs,
    ROUND(q.cpu_time/1000000,2)         AS cpu_secs,
    ROUND(q.buffer_gets/GREATEST(q.executions,1),0) AS bgets_per_exec,
    q.rows_processed,
    q.last_active_time,
    q.parsing_schema_name,
    q.degree
FROM
    GV$SQL q
    JOIN GV$SQLAREA s ON q.sql_id = s.sql_id AND q.inst_id = s.inst_id
WHERE
    q.px_servers_executions > 0
    AND q.last_active_time > SYSDATE - 1/24  -- last hour
ORDER BY
    q.px_servers_executions DESC
FETCH FIRST 20 ROWS ONLY;

-- Top resource-consuming SQL last 1 hour by elapsed
PROMPT -- Top SQL by elapsed time (last 1 hour, all instances):
SELECT
    inst_id,
    sql_id,
    SUBSTR(sql_text,1,80)               AS sql_text,
    executions,
    ROUND(elapsed_time/1000000,2)       AS elapsed_secs,
    ROUND(cpu_time/1000000,2)           AS cpu_secs,
    disk_reads,
    buffer_gets,
    rows_processed,
    px_servers_executions,
    parsing_schema_name
FROM
    GV$SQL
WHERE
    last_active_time > SYSDATE - 1/24
ORDER BY
    elapsed_time DESC
FETCH FIRST 25 ROWS ONLY;

-- Any SQL with ORA errors
PROMPT -- SQL with execution errors (last 24h):
SELECT
    inst_id,
    sql_id,
    SUBSTR(sql_text,1,80)               AS sql_text,
    executions,
    end_of_fetch_count,
    parse_calls,
    parsing_schema_name,
    last_active_time
FROM
    GV$SQL
WHERE
    end_of_fetch_count < executions      -- completed without full fetch = likely errored
    AND executions > 0
    AND last_active_time > SYSDATE - 1/24
    AND px_servers_executions > 0
ORDER BY
    (executions - end_of_fetch_count) DESC
FETCH FIRST 20 ROWS ONLY;

-- SQL plan with high DOP on instance
PROMPT -- Active SQL plans requesting high degree of parallelism:
SELECT
    sq.inst_id,
    sq.sql_id,
    sq.child_number,
    sq.degree,
    sq.instances,
    sq.px_servers_executions,
    sq.parsing_schema_name,
    SUBSTR(sq.sql_text,1,60)            AS sql_preview
FROM
