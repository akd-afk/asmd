PROMPT -- Keystore errors from alert log (last 2h):
SELECT
    inst_id,
    to_char(originating_timestamp,'YYYY-MM-DD HH24:MI:SS')  AS log_time,
    message_text
FROM
    GV$DIAG_ALERT_EXT
WHERE
    originating_timestamp > SYSTIMESTAMP - INTERVAL '2' HOUR
    AND (
        UPPER(message_text) LIKE '%OKV%'
        OR UPPER(message_text) LIKE '%KEYSTORE%'
        OR UPPER(message_text) LIKE '%WALLET%'
        OR UPPER(message_text) LIKE '%TDE%'
        OR UPPER(message_text) LIKE '%28374%'
        OR UPPER(message_text) LIKE '%28375%'
    )
ORDER BY
    originating_timestamp DESC;

