-- Archive log generation rate (useful for bandwidth estimation)
PROMPT -- Archivelog generation rate last 24h (per hour):
SELECT
    inst_id,
    to_char(TRUNC(first_time,'HH'),'YYYY-MM-DD HH24') AS log_hour,
    COUNT(*)                            AS log_count,
    ROUND(SUM(blocks * block_size)/1024/1024,1) AS total_mb
FROM
    GV$ARCHIVED_LOG
WHERE
    first_time > SYSDATE - 1
    AND standby_dest = 'NO'
GROUP BY
    inst_id,
    TRUNC(first_time,'HH')
ORDER BY
    inst_id, log_hour;

