PROMPT SECTION 14: BLOCKING / LOCKING (PQ SLAVES CAN DEADLOCK)
PROMPT ================================================================================

PROMPT -- Current lock holders and waiters:
SELECT
    h.inst_id                           AS holder_inst,
    h.sid                               AS holder_sid,
    h.serial#                           AS holder_serial,
    h.username                          AS holder_user,
    h.sql_id                            AS holder_sql,
    h.event                             AS holder_event,
    w.inst_id                           AS waiter_inst,
    w.sid                               AS waiter_sid,
    w.username                          AS waiter_user,
    w.event                             AS waiter_event,
    w.seconds_in_wait
FROM
    GV$SESSION h
    JOIN GV$SESSION w
        ON w.blocking_instance = h.inst_id
        AND w.blocking_session = h.sid
WHERE
    w.blocking_session IS NOT NULL
ORDER BY
    w.seconds_in_wait DESC;

PROMPT -- Enqueue waits (row locks, TX, etc.):
SELECT
    inst_id,
    event,
    total_waits,
    ROUND(time_waited_micro/1000000,2)  AS wait_secs,
    ROUND(average_wait/1000,2)          AS avg_ms
FROM
    GV$SYSTEM_EVENT
WHERE
    wait_class = 'Concurrency'
    OR wait_class = 'Application'
ORDER BY
    time_waited_micro DESC
FETCH FIRST 20 ROWS ONLY;

