-- Active PQ coordinators and slave counts
PROMPT -- Active parallel coordinators right now:
SELECT
    qc.inst_id,
    qc.sid                          AS coord_sid,
    qc.serial#                      AS coord_serial,
    qc.username,
    qc.sql_id,
    qc.status,
    qc.event,
    qc.seconds_in_wait,
    COUNT(qs.sid)                   AS slave_count,
    qc.machine,
    qc.program
FROM
    GV$SESSION qc
    LEFT JOIN GV$PX_SESSION qs
        ON qs.qcsid = qc.sid
        AND qs.inst_id = qc.inst_id
        AND qs.sid != qc.sid
WHERE
    qc.sql_id IS NOT NULL
    AND EXISTS (
        SELECT 1 FROM GV$PX_SESSION px
        WHERE px.qcsid = qc.sid AND px.inst_id = qc.inst_id
    )
GROUP BY
    qc.inst_id, qc.sid, qc.serial#, qc.username,
    qc.sql_id, qc.status, qc.event,
    qc.seconds_in_wait, qc.machine, qc.program
ORDER BY
    slave_count DESC;

