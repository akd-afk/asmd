PROMPT -- ORA-12805 hit count last 2 hours:
SELECT
    a.inst_id,
    COUNT(*)                            AS ora12805_incident_count
FROM
    GV$DIAG_INCIDENT a
    JOIN V$DIAG_PROBLEM p ON a.problem_id = p.problem_id
WHERE
    a.create_time > SYSTIMESTAMP - INTERVAL '2' HOUR
    AND p.problem_key LIKE '%12805%'
GROUP BY a.inst_id
ORDER BY a.inst_id;

PROMPT -- Large pool free vs total:
SELECT
    inst_id,
    SUM(CASE WHEN name = 'free memory' THEN bytes ELSE 0 END)/1024/1024     AS free_mb,
    SUM(bytes)/1024/1024                                                     AS total_pool_mb,
    ROUND(SUM(CASE WHEN name = 'free memory' THEN bytes ELSE 0 END)/
          NULLIF(SUM(bytes),0)*100,1)                                        AS pct_free
FROM
    GV$SGASTAT
WHERE
    pool = 'large pool'
GROUP BY inst_id
ORDER BY inst_id;

PROMPT -- PGA over-allocation counter (non-zero = memory pressure):
SELECT inst_id, name, value
FROM GV$PGASTAT
WHERE name = 'over allocation count'
ORDER BY inst_id;

PROMPT -- Active PQ coordinators right now:
SELECT inst_id, COUNT(*) AS active_qc
FROM GV$PX_SESSION
WHERE sid = qcsid
GROUP BY inst_id
ORDER BY inst_id;

