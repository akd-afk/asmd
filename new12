WHERE
    TO_NUMBER(TRIM(sq.degree)) > 4      -- adjust threshold as needed
    AND sq.last_active_time > SYSDATE - 1/24
ORDER BY
    TO_NUMBER(TRIM(sq.degree)) DESC
